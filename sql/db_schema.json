{
  "schema": "ahmf",
  "tables": {
    "users": {
      "columns": {
        "user_id": "UUID PK DEFAULT gen_random_uuid()",
        "email": "VARCHAR(255) UNIQUE NOT NULL",
        "password_hash": "VARCHAR(255)",
        "display_name": "VARCHAR(255)",
        "role": "VARCHAR(50) DEFAULT 'user'",
        "created_at": "TIMESTAMPTZ DEFAULT NOW()",
        "updated_at": "TIMESTAMPTZ DEFAULT NOW()"
      }
    },
    "deals": {
      "columns": {
        "deal_id": "UUID PK DEFAULT gen_random_uuid()",
        "title": "VARCHAR(500) NOT NULL",
        "project_type": "VARCHAR(50) DEFAULT 'feature_film'",
        "genre": "VARCHAR(100)",
        "status": "VARCHAR(50) DEFAULT 'pipeline' [active|pipeline|closed|declined]",
        "loan_amount": "NUMERIC(15,2)",
        "currency": "VARCHAR(10) DEFAULT 'USD'",
        "interest_rate": "NUMERIC(5,2)",
        "term_months": "INTEGER",
        "borrower_name": "VARCHAR(500)",
        "producer": "VARCHAR(500)",
        "director": "VARCHAR(500)",
        "cast_summary": "TEXT",
        "budget": "NUMERIC(15,2)",
        "territory": "TEXT",
        "collateral_type": "VARCHAR(255)",
        "origination_date": "DATE",
        "maturity_date": "DATE",
        "notes": "JSONB DEFAULT '{}'",
        "created_by": "UUID FK->users(user_id)",
        "created_at": "TIMESTAMPTZ DEFAULT NOW()",
        "updated_at": "TIMESTAMPTZ DEFAULT NOW()"
      }
    },
    "contacts": {
      "columns": {
        "contact_id": "UUID PK DEFAULT gen_random_uuid()",
        "name": "VARCHAR(500) NOT NULL",
        "company": "VARCHAR(500)",
        "role": "VARCHAR(255)",
        "email": "VARCHAR(255)",
        "phone": "VARCHAR(100)",
        "contact_type": "VARCHAR(50) DEFAULT 'other' [distributor|producer|sales_agent|talent|financier|legal|other]",
        "credit_score": "NUMERIC(5,2)",
        "notes": "TEXT",
        "created_by": "UUID FK->users(user_id)",
        "created_at": "TIMESTAMPTZ DEFAULT NOW()",
        "updated_at": "TIMESTAMPTZ DEFAULT NOW()"
      }
    },
    "sales_contracts": {
      "columns": {
        "contract_id": "UUID PK DEFAULT gen_random_uuid()",
        "deal_id": "UUID FK->deals(deal_id) ON DELETE CASCADE",
        "territory": "VARCHAR(255)",
        "distributor_id": "UUID FK->contacts(contact_id)",
        "mg_amount": "NUMERIC(15,2)",
        "currency": "VARCHAR(10) DEFAULT 'USD'",
        "payment_schedule": "JSONB DEFAULT '[]'",
        "status": "VARCHAR(50) DEFAULT 'draft'",
        "created_by": "UUID FK->users(user_id)",
        "created_at": "TIMESTAMPTZ DEFAULT NOW()"
      }
    },
    "collections": {
      "columns": {
        "collection_id": "UUID PK DEFAULT gen_random_uuid()",
        "contract_id": "UUID FK->sales_contracts(contract_id) ON DELETE CASCADE",
        "amount_due": "NUMERIC(15,2)",
        "amount_received": "NUMERIC(15,2) DEFAULT 0",
        "due_date": "DATE",
        "received_date": "DATE",
        "status": "VARCHAR(50) DEFAULT 'pending'"
      }
    },
    "credit_ratings": {
      "columns": {
        "rating_id": "UUID PK DEFAULT gen_random_uuid()",
        "contact_id": "UUID FK->contacts(contact_id) ON DELETE CASCADE",
        "score": "NUMERIC(5,2)",
        "payment_reliability": "NUMERIC(5,2)",
        "risk_tier": "VARCHAR(20) [AAA|AA|A|BBB|BB|B]",
        "factors": "JSONB DEFAULT '{}'",
        "rated_by": "UUID FK->users(user_id)",
        "rated_at": "TIMESTAMPTZ DEFAULT NOW()"
      }
    },
    "transactions": {
      "columns": {
        "txn_id": "UUID PK DEFAULT gen_random_uuid()",
        "deal_id": "UUID FK->deals(deal_id) ON DELETE CASCADE",
        "txn_type": "VARCHAR(50) [disbursement|repayment|fee|interest]",
        "amount": "NUMERIC(15,2)",
        "currency": "VARCHAR(10) DEFAULT 'USD'",
        "counterparty_id": "UUID FK->contacts(contact_id)",
        "reference": "VARCHAR(500)",
        "posted_date": "DATE DEFAULT CURRENT_DATE",
        "created_by": "UUID FK->users(user_id)",
        "created_at": "TIMESTAMPTZ DEFAULT NOW()"
      }
    },
    "messages": {
      "columns": {
        "message_id": "UUID PK DEFAULT gen_random_uuid()",
        "deal_id": "UUID FK->deals(deal_id) ON DELETE SET NULL",
        "from_user": "UUID FK->users(user_id)",
        "to_user": "UUID FK->users(user_id)",
        "subject": "VARCHAR(500)",
        "body": "TEXT",
        "message_type": "VARCHAR(50) DEFAULT 'note' [note|task|message]",
        "due_date": "DATE",
        "status": "VARCHAR(50) DEFAULT 'open'",
        "created_at": "TIMESTAMPTZ DEFAULT NOW()"
      }
    },
    "deal_documents": {
      "columns": {
        "doc_id": "UUID PK DEFAULT gen_random_uuid()",
        "deal_id": "UUID FK->deals(deal_id) ON DELETE CASCADE",
        "doc_type": "VARCHAR(100)",
        "filename": "VARCHAR(500)",
        "file_path": "TEXT",
        "version": "INTEGER DEFAULT 1",
        "uploaded_by": "UUID FK->users(user_id)",
        "uploaded_at": "TIMESTAMPTZ DEFAULT NOW()"
      }
    },
    "deal_contacts": {
      "columns": {
        "deal_id": "UUID FK->deals(deal_id) ON DELETE CASCADE (composite PK)",
        "contact_id": "UUID FK->contacts(contact_id) ON DELETE CASCADE (composite PK)",
        "relationship_type": "VARCHAR(100)"
      }
    },
    "deal_approvals": {
      "columns": {
        "approval_id": "UUID PK DEFAULT gen_random_uuid()",
        "deal_id": "UUID FK->deals(deal_id) ON DELETE CASCADE",
        "stage": "VARCHAR(100)",
        "status": "VARCHAR(50) DEFAULT 'pending'",
        "reviewer": "UUID FK->users(user_id)",
        "comments": "TEXT",
        "decided_at": "TIMESTAMPTZ"
      }
    },
    "deal_balances": {
      "columns": {
        "balance_id": "UUID PK DEFAULT gen_random_uuid()",
        "deal_id": "UUID FK->deals(deal_id) ON DELETE CASCADE",
        "balance_type": "VARCHAR(50)",
        "amount": "NUMERIC(15,2)",
        "as_of_date": "DATE DEFAULT CURRENT_DATE",
        "currency": "VARCHAR(10) DEFAULT 'USD'"
      }
    },
    "contact_activities": {
      "columns": {
        "activity_id": "UUID PK DEFAULT gen_random_uuid()",
        "contact_id": "UUID FK->contacts(contact_id) ON DELETE CASCADE",
        "activity_type": "VARCHAR(100)",
        "description": "TEXT",
        "created_by": "UUID FK->users(user_id)",
        "created_at": "TIMESTAMPTZ DEFAULT NOW()"
      }
    }
  }
}
